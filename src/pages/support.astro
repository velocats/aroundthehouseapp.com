---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegalArticle from '../components/LegalArticle.astro';
---
<BaseLayout
  title="Support — Around The House Home Maintenance App"
  description="Get help with Around The House, including iCloud sync, purchases, home maintenance records, reminders, receipts, warranties, and app support."
  canonicalPath="/support/"
  page="legal"
  compactFooter={true}
>
  <LegalArticle kicker="Help" title="Around The House Support">
    <p>Need help with Around The House? Send a message below or email <a href="mailto:support@quiettoolsapps.com">support@quiettoolsapps.com</a>.</p>

    <form class="support-form" id="supportForm" action="https://formsubmit.co/support@quiettoolsapps.com" method="POST">
      <input type="hidden" name="_subject" value="New Around The House support request" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_next" value="https://aroundthehouseapp.com/support/?sent=1" />
      <input class="form-honeypot" type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="form-field">
        <label for="support-topic">What can we help with? <span>Required</span></label>
        <select id="support-topic" name="topic" required>
          <option value="" selected disabled>Choose a topic</option>
          <option value="Bug report">Bug report</option>
          <option value="iCloud sync">iCloud sync</option>
          <option value="Purchase or restore purchase">Purchase or restore purchase</option>
          <option value="Feature question">Feature question</option>
          <option value="Feedback or suggestion">Feedback or suggestion</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="form-row">
        <div class="form-field">
          <label for="support-name">Your name</label>
          <input id="support-name" name="name" type="text" autocomplete="name" placeholder="Optional" />
        </div>
        <div class="form-field">
          <label for="support-email">Your email <span>Required</span></label>
          <input id="support-email" name="email" type="email" autocomplete="email" required placeholder="So we can reply" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-field">
          <label for="support-device">Device</label>
          <select id="support-device" name="device">
            <option value="">Choose a device</option>
            <option value="iPhone">iPhone</option>
            <option value="iPad">iPad</option>
            <option value="Mac">Mac</option>
            <option value="Multiple devices">Multiple devices</option>
          </select>
        </div>
        <div class="form-field">
          <label for="support-version">System version</label>
          <input id="support-version" name="systemVersion" type="text" placeholder="Example: iOS 26" />
        </div>
      </div>

      <div class="form-field">
        <label for="support-message">What happened? <span>Required</span></label>
        <textarea id="support-message" name="message" rows="8" required placeholder="Tell us what you were trying to do, what happened instead, and any steps that might help us reproduce it."></textarea>
      </div>

      <button class="button" type="submit">Send support request</button>
      <p class="form-help">Your message will be sent directly to the Around The House support inbox.</p>
      <p class="form-success" id="formSuccess" role="status" aria-live="polite" hidden>Thanks—your support request was sent. We’ll reply by email.</p>
    </form>

    <h2>Helpful details to include</h2>
    <ul>
      <li>Your device type: iPhone, iPad, or Mac.</li>
      <li>Your iOS, iPadOS, or macOS version.</li>
      <li>What you were trying to do.</li>
      <li>What happened instead.</li>
      <li>Screenshots, if they help explain the issue.</li>
    </ul>
    <h2>iCloud sync notes</h2>
    <p>Around The House syncs through your own iCloud account when iCloud is enabled. Make sure your devices are signed into the same Apple Account and have iCloud access available. Around The House also works offline; changes can sync after your device is back online.</p>
    <h2>Purchases</h2>
    <p>If Pro features do not appear after purchase, open Around The House settings and use Restore Purchases. App Store purchases are handled by Apple.</p>
  </LegalArticle>
  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const success = document.getElementById('formSuccess');
    if (params.get('sent') === '1' && success) {
      success.hidden = false;
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  </script>
</BaseLayout>
