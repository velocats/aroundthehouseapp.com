---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegalArticle from '../components/LegalArticle.astro';
---
<BaseLayout
  title="Terms of Use — Around The House"
  description="Read the terms of use for Around The House, including the Apple Standard End User License Agreement and support contact details."
  canonicalPath="/terms/"
  page="legal"
  compactFooter={true}
>
  <LegalArticle kicker="Terms" title="Terms of Use">
    <p>Around The House uses Apple’s standard Terms of Use for apps distributed through the App Store.</p>
    <p><a href="https://www.apple.com/legal/internet-services/itunes/dev/stdeula/">Apple Standard End User License Agreement</a></p>
    <h2>Support</h2>
    <p>Questions can be sent to <a href="mailto:support@aroundthehouseapp.com">support@aroundthehouseapp.com</a>.</p>
  </LegalArticle>
</BaseLayout>
