---
const { page = 'home' } = Astro.props;
const isHome = page === 'home';
---
<header class="site-header">
  <nav class="container nav" aria-label="Main navigation">
    <a class="brand" href="/" aria-label="Around The House home">
      <img src="/assets/icons/around-the-house-icon.png" alt="Around The House app icon" />
      <span>Around The House</span>
    </a>
    {isHome ? (
      <div class="nav-links">
        <a href="#how-it-works">How it works</a>
        <a href="#features">What it tracks</a>
        <a href="#pricing">Pricing</a>
        <a href="/support/">Support</a>
        <a class="button disabled" href="#app-store" aria-disabled="true">App Store coming soon</a>
      </div>
    ) : (
      <div class="nav-links">
        <a href="/#how-it-works">How it works</a>
        <a href="/#features">What it tracks</a>
        <a href="/support/">Support</a>
        <a class="button secondary" href="/">Home</a>
      </div>
    )}
  </nav>
</header>
